{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/pages/contact.html", "destination": "/contact/", "permanent": true },
    { "source": "/pages/realisations.html", "destination": "/realisations/", "permanent": true },
    { "source": "/pages/prestations.html", "destination": "/prestations/", "permanent": true },
    { "source": "/pages/recrutement.html", "destination": "/recrutement/", "permanent": true },
    { "source": "/pages/cookies.html", "destination": "/cookies/", "permanent": true },
    { "source": "/pages/atelier.html", "destination": "/atelier/", "permanent": true },
    { "source": "/pages/technologies.html", "destination": "/technologies/", "permanent": true },
    { "source": "/pages/zones-intervention.html", "destination": "/zones-intervention/", "permanent": true },
    { "source": "/prestations/index.html", "destination": "/prestations/", "permanent": true },
    { "source": "/prestations/:slug/index.html", "destination": "/prestations/:slug/", "permanent": true },
    { "source": "/faq/index.html", "destination": "/faq/", "permanent": true },
    { "source": "/faq/:slug/index.html", "destination": "/faq/:slug/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://script.google.com https://script.googleusercontent.com; form-action 'self'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}


